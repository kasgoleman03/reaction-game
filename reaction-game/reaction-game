<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reflex — Reaction Timer</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* ==========================================================
     Design tokens — single source of truth for color, type, motion.
     Keeping these as CSS variables means the JS layer can read
     them too (via getComputedStyle) if we ever want to share
     palette values with Three.js. For now the 3D layer holds its
     own palette constants — see the THREE.JS SCENE block below.
     ========================================================== */
      :root {
        --bg: #0a0a12;
        --surface: #13131f;
        --card: #1e1e2e;
        --border: #2a2a3d;
        --text: #e8e8f0;
        --text-dim: #8a8aa0;
        --text-mute: #5a5a75;

        --accent: #7f77dd;
        --success: #1d9e75;
        --warn: #ba7517;
        --danger: #a32d2d;

        --font-display: 'Inter', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, monospace;

        --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        height: 100%;
        overflow: hidden;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-display);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* The Three.js canvas is fixed at the back of the stack.
     Pointer-events disabled so it never steals input from the UI. */
      #scene {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
        /* A subtle radial vignette darkens the edges and pulls focus
       toward the center — keeps the 3D layer from competing with UI. */
        background: radial-gradient(
          ellipse at center,
          transparent 0%,
          var(--bg) 85%
        );
      }

      /* All UI lives above the scene. */
      .ui {
        position: relative;
        z-index: 10;
        width: 100vw;
        height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }

      /* ----- HEADER ----- */
      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 40px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
        font-size: 14px;
      }
      .brand-mark {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        background: var(--accent);
        box-shadow: 0 0 12px rgba(127, 119, 221, 0.6);
      }
      .header-meta {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-mute);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      /* ----- TARGET (the click area) ----- */
      .stage {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 24px;
      }

      .target {
        width: min(560px, 88vw);
        aspect-ratio: 1.6 / 1;
        max-height: 60vh;
        border-radius: 20px;
        background: var(--card);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        cursor: pointer;
        user-select: none;
        position: relative;
        overflow: hidden;
        transition:
          background-color 320ms var(--ease-out),
          border-color 320ms var(--ease-out),
          transform 200ms var(--ease-out),
          box-shadow 320ms var(--ease-out);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.03) inset,
          0 30px 80px -20px rgba(0, 0, 0, 0.6);
      }
      .target:hover {
        transform: translateY(-2px);
      }
      .target:active {
        transform: translateY(0);
      }

      /* Per-state styling — driven by data-state attribute on .target.
     This is the visual half of the state machine. */
      .target[data-state='idle'] {
        background: var(--card);
        border-color: var(--border);
      }
      .target[data-state='waiting'] {
        background: #2a1f1f;
        border-color: #4a2a2a;
      }
      .target[data-state='stimulus'] {
        background: var(--success);
        border-color: #25c490;
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.08) inset,
          0 0 80px 0 rgba(29, 158, 117, 0.5),
          0 30px 80px -20px rgba(0, 0, 0, 0.6);
      }
      .target[data-state='result'] {
        background: var(--card);
        border-color: var(--border);
      }
      .target[data-state='early'] {
        background: #2e1a1a;
        border-color: var(--danger);
      }

      .target-label {
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-mute);
        margin-bottom: 18px;
      }
      .target[data-state='waiting'] .target-label {
        color: #b86060;
      }
      .target[data-state='stimulus'] .target-label {
        color: rgba(255, 255, 255, 0.7);
      }
      .target[data-state='early'] .target-label {
        color: var(--danger);
      }

      .target-headline {
        font-family: var(--font-display);
        font-size: clamp(22px, 3.4vw, 32px);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 6px;
      }
      .target[data-state='stimulus'] .target-headline {
        color: #fff;
      }

      .target-sub {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-dim);
        letter-spacing: 0.04em;
      }
      .target[data-state='stimulus'] .target-sub {
        color: rgba(255, 255, 255, 0.85);
      }

      /* The hero number — reaction time. Monospace so layout never shifts
     between e.g. 187ms and 244ms. */
      .result-time {
        font-family: var(--font-mono);
        font-size: clamp(56px, 11vw, 112px);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: 8px;
        transition: color 320ms var(--ease-out);
      }
      .result-time .unit {
        font-size: 0.4em;
        font-weight: 500;
        color: var(--text-mute);
        margin-left: 6px;
        letter-spacing: 0;
      }
      .result-time[data-grade='fast'] {
        color: var(--success);
      }
      .result-time[data-grade='average'] {
        color: var(--warn);
      }
      .result-time[data-grade='slow'] {
        color: var(--danger);
      }

      .result-grade {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 4px;
      }

      /* Hide/show panels per state without rebuilding DOM. */
      .panel {
        display: none;
        flex-direction: column;
        align-items: center;
      }
      .panel.active {
        display: flex;
      }

      /* Pulse animation for the stimulus reveal — gives the click target
     a clear "GO" energy without distracting motion before that. */
      @keyframes stimulus-pulse {
        0% {
          transform: scale(0.96);
        }
        60% {
          transform: scale(1.015);
        }
        100% {
          transform: scale(1);
        }
      }
      .target[data-state='stimulus'] .panel.active {
        animation: stimulus-pulse 280ms var(--ease-out);
      }

      /* ----- STATS ROW ----- */
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        padding: 0 40px 32px;
        background: transparent;
      }
      .stat {
        background: rgba(19, 19, 31, 0.7);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 22px;
        margin: 0 4px;
      }
      .stat-label {
        font-family: var(--font-display);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-mute);
        margin-bottom: 10px;
      }
      .stat-value {
        font-family: var(--font-mono);
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
      }
      .stat-value .unit {
        font-size: 13px;
        color: var(--text-mute);
        font-weight: 500;
        margin-left: 4px;
      }
      .stat-value.empty {
        color: var(--text-mute);
      }

      /* ----- KEY HINT ----- */
      .key-hint {
        position: absolute;
        bottom: 18px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        color: var(--text-mute);
        text-transform: uppercase;
        pointer-events: none;
      }
      kbd {
        font-family: var(--font-mono);
        font-size: 10px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 2px 6px;
        margin: 0 2px;
        color: var(--text-dim);
      }

      /* ----- RESPONSIVE ----- */
      @media (max-width: 720px) {
        .header {
          padding: 20px 22px;
        }
        .stats {
          grid-template-columns: repeat(2, 1fr);
          gap: 8px;
          padding: 0 18px 22px;
        }
        .stat {
          margin: 0;
        }
        .target {
          aspect-ratio: 1 / 1;
          max-height: 55vh;
        }
      }

      /* Reduced motion respect — kill the pulse, keep the rest. */
      @media (prefers-reduced-motion: reduce) {
        .target[data-state='stimulus'] .panel.active {
          animation: none;
        }
        .target {
          transition-duration: 100ms;
        }
      }
    </style>
  </head>
  <body>
    <!-- 3D ambient layer — always first in the DOM, pinned behind the UI. -->
    <canvas id="scene" aria-hidden="true"></canvas>

    <div class="ui">
      <header class="header">
        <div class="brand">
          <span class="brand-mark"></span>
          <span>REFLEX</span>
        </div>
        <div class="header-meta" id="header-meta">REACTION TEST</div>
      </header>

      <main class="stage">
        <!-- The target IS the game surface. data-state drives everything visual. -->
        <div
          class="target"
          id="target"
          data-state="idle"
          tabindex="0"
          role="button"
          aria-label="Reaction target"
        >
          <!-- IDLE -->
          <div class="panel active" data-panel="idle">
            <div class="target-label">Ready</div>
            <div class="target-headline">Click to begin</div>
            <div class="target-sub">React the moment it turns green</div>
          </div>

          <!-- WAITING -->
          <div class="panel" data-panel="waiting">
            <div class="target-label">Hold</div>
            <div class="target-headline">Wait for green…</div>
            <div class="target-sub">Don't click yet</div>
          </div>

          <!-- STIMULUS -->
          <div class="panel" data-panel="stimulus">
            <div class="target-label">Now</div>
            <div class="target-headline">CLICK</div>
            <div class="target-sub">— or press space —</div>
          </div>

          <!-- RESULT -->
          <div class="panel" data-panel="result">
            <div class="result-time" id="result-time" data-grade="average">
              <span id="result-ms">0</span><span class="unit">ms</span>
            </div>
            <div class="result-grade" id="result-grade">—</div>
            <div class="target-sub">Click to try again</div>
          </div>

          <!-- EARLY (penalty) -->
          <div class="panel" data-panel="early">
            <div class="target-label" style="color: var(--danger)">
              Too early
            </div>
            <div class="target-headline">Wait for the green</div>
            <div class="target-sub">Click to try again</div>
          </div>

          <span class="key-hint"><kbd>SPACE</kbd> works too</span>
        </div>
      </main>

      <!-- Live session statistics. Mono font everywhere a number lives. -->
      <section class="stats" aria-label="Session statistics">
        <div class="stat">
          <div class="stat-label">Last</div>
          <div class="stat-value empty" id="stat-last">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Best</div>
          <div class="stat-value empty" id="stat-best">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Average</div>
          <div class="stat-value empty" id="stat-avg">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Attempts</div>
          <div class="stat-value" id="stat-count">0</div>
        </div>
      </section>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
      /* ============================================================
   Shared state object — the contract between game logic and the
   3D scene. Game logic writes to this; the Three.js render loop
   reads from it on every frame. No direct DOM coupling between
   the two layers; the 3D scene never queries the DOM.
   ============================================================ */
      const sharedState = {
        phase: 'idle', // 'idle' | 'waiting' | 'stimulus' | 'result' | 'early'
        grade: null, // 'fast' | 'average' | 'slow' | null  (only set during 'result')
        stimulusAt: 0, // performance.now() when last stimulus fired — used for the burst pulse
      };

      // =============================================================
      // === THREE.JS SCENE ==========================================
      // =============================================================
      // A small, self-contained ambient layer. Reads sharedState every
      // frame and adjusts color, motion, and intensity accordingly.
      // Decoupled from game logic — could be removed entirely without
      // breaking gameplay.
      // =============================================================
      (() => {
        const canvas = document.getElementById('scene');

        const renderer = new THREE.WebGLRenderer({
          canvas,
          antialias: true,
          alpha: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(window.innerWidth, window.innerHeight, false);
        renderer.setClearColor(0x0a0a12, 1);

        const scene = new THREE.Scene();
        scene.fog = new THREE.Fog(0x0a0a12, 8, 22);

        const camera = new THREE.PerspectiveCamera(
          55,
          window.innerWidth / window.innerHeight,
          0.1,
          100,
        );
        camera.position.set(0, 0, 10);

        // Lighting — one soft ambient + a directional fill + a moving
        // point light that we recolor to match game state.
        const ambient = new THREE.AmbientLight(0x4a4a6a, 0.5);
        scene.add(ambient);

        const directional = new THREE.DirectionalLight(0x8a82e8, 0.6);
        directional.position.set(4, 6, 4);
        scene.add(directional);

        const stateLight = new THREE.PointLight(0x7f77dd, 1.2, 30);
        stateLight.position.set(0, 0, 6);
        scene.add(stateLight);

        // State-driven palette. Targets are interpolated toward on each frame
        // so transitions feel smooth rather than snapping.
        const PALETTE = {
          idle: {
            primary: 0x7f77dd,
            secondary: 0x4a4475,
            light: 0x7f77dd,
            intensity: 1.0,
            speed: 1.0,
          },
          waiting: {
            primary: 0x3a3556,
            secondary: 0x2a2540,
            light: 0x5a5575,
            intensity: 0.7,
            speed: 0.35,
          },
          stimulus: {
            primary: 0x1d9e75,
            secondary: 0x25c490,
            light: 0x25e0a0,
            intensity: 2.4,
            speed: 2.4,
          },
          result_fast: {
            primary: 0x1d9e75,
            secondary: 0x25c490,
            light: 0x1d9e75,
            intensity: 1.4,
            speed: 1.2,
          },
          result_average: {
            primary: 0xba7517,
            secondary: 0xd08a28,
            light: 0xba7517,
            intensity: 1.4,
            speed: 1.0,
          },
          result_slow: {
            primary: 0xa32d2d,
            secondary: 0xc04040,
            light: 0xa32d2d,
            intensity: 1.4,
            speed: 0.8,
          },
          early: {
            primary: 0xa32d2d,
            secondary: 0x602020,
            light: 0xa32d2d,
            intensity: 1.6,
            speed: 0.5,
          },
        };

        // Resolve which palette entry to use given the shared state.
        const paletteFor = (s) => {
          if (s.phase === 'result' && s.grade)
            return PALETTE['result_' + s.grade];
          return PALETTE[s.phase] || PALETTE.idle;
        };

        // Spawn 9 floating shapes — kept low for performance, distributed
        // around (but not directly in front of) the central UI focal point.
        const SHAPES = [];
        const geometries = [
          new THREE.IcosahedronGeometry(0.9, 0),
          new THREE.OctahedronGeometry(1.0, 0),
          new THREE.TorusKnotGeometry(0.55, 0.18, 64, 8),
          new THREE.IcosahedronGeometry(0.7, 0),
          new THREE.OctahedronGeometry(0.85, 0),
        ];

        for (let i = 0; i < 9; i++) {
          const geo = geometries[i % geometries.length];
          const mat = new THREE.MeshStandardMaterial({
            color: 0x7f77dd,
            roughness: 0.35,
            metalness: 0.4,
            flatShading: true,
            transparent: true,
            opacity: 0.55,
          });
          const mesh = new THREE.Mesh(geo, mat);

          // Place shapes in a ring around the focal point — push them out
          // of the center so they never visually compete with the UI card.
          const angle = (i / 9) * Math.PI * 2 + Math.random() * 0.4;
          const radius = 5.5 + Math.random() * 2.2;
          mesh.position.set(
            Math.cos(angle) * radius,
            Math.sin(angle) * radius * 0.55 + (Math.random() - 0.5) * 1.5,
            -2 - Math.random() * 4,
          );
          mesh.rotation.set(
            Math.random() * Math.PI,
            Math.random() * Math.PI,
            0,
          );

          // Per-shape motion params so each drifts slightly differently.
          SHAPES.push({
            mesh,
            mat,
            basePos: mesh.position.clone(),
            driftSpeed: 0.2 + Math.random() * 0.4,
            driftPhase: Math.random() * Math.PI * 2,
            rotSpeed: new THREE.Vector3(
              (Math.random() - 0.5) * 0.4,
              (Math.random() - 0.5) * 0.4,
              (Math.random() - 0.5) * 0.2,
            ),
          });
          scene.add(mesh);
        }

        // Smoothly interpolated values. We don't snap to the new palette
        // on state change — we ease toward it for a more polished feel.
        const current = {
          primary: new THREE.Color(0x7f77dd),
          secondary: new THREE.Color(0x4a4475),
          light: new THREE.Color(0x7f77dd),
          intensity: 1.0,
          speed: 1.0,
          burst: 0,
        };
        const tmpColor = new THREE.Color();
        const lerp = (a, b, t) => a + (b - a) * t;

        const clock = new THREE.Clock();

        function animate() {
          requestAnimationFrame(animate);
          const dt = Math.min(clock.getDelta(), 0.05); // clamp to avoid huge jumps on tab refocus
          const t = clock.elapsedTime;

          // Pull target palette from the shared state object.
          const target = paletteFor(sharedState);

          // Ease toward target color/intensity. Higher factor = snappier.
          const k = 1 - Math.pow(0.001, dt); // framerate-independent lerp
          tmpColor.setHex(target.primary);
          current.primary.lerp(tmpColor, k);
          tmpColor.setHex(target.secondary);
          current.secondary.lerp(tmpColor, k);
          tmpColor.setHex(target.light);
          current.light.lerp(tmpColor, k);
          current.intensity = lerp(current.intensity, target.intensity, k);
          current.speed = lerp(current.speed, target.speed, k);

          // Stimulus burst — a short outward pulse that decays over ~0.6s,
          // triggered by stamping sharedState.stimulusAt. Purely visual.
          const sinceStimulus =
            (performance.now() - sharedState.stimulusAt) / 1000;
          const burstTarget =
            sharedState.phase === 'stimulus' && sinceStimulus < 0.6
              ? Math.max(0, 1 - sinceStimulus / 0.6)
              : 0;
          current.burst = lerp(
            current.burst,
            burstTarget,
            1 - Math.pow(0.0001, dt),
          );

          // Light follows the state palette + intensity.
          stateLight.color.copy(current.light);
          stateLight.intensity = current.intensity + current.burst * 1.5;

          // Update each shape — alternating between primary and secondary
          // colors gives the cluster visual variety without breaking cohesion.
          SHAPES.forEach((s, i) => {
            const useSecondary = i % 2 === 1;
            s.mat.color.copy(
              useSecondary ? current.secondary : current.primary,
            );
            s.mat.opacity = 0.45 + current.burst * 0.3;

            // Rotation speed scales with the state speed multiplier.
            s.mesh.rotation.x += s.rotSpeed.x * dt * current.speed;
            s.mesh.rotation.y += s.rotSpeed.y * dt * current.speed;
            s.mesh.rotation.z += s.rotSpeed.z * dt * current.speed;

            // Gentle floating drift around base position.
            const drift = Math.sin(t * s.driftSpeed + s.driftPhase) * 0.4;
            s.mesh.position.x = s.basePos.x + Math.cos(t * 0.3 + i) * 0.3;
            s.mesh.position.y = s.basePos.y + drift;

            // Burst pushes shapes outward from origin briefly.
            if (current.burst > 0.01) {
              const dir = s.basePos.clone().normalize();
              s.mesh.position.addScaledVector(dir, current.burst * 0.6);
            }
          });

          renderer.render(scene, camera);
        }

        function onResize() {
          const w = window.innerWidth,
            h = window.innerHeight;
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
          renderer.setSize(w, h, false);
        }
        window.addEventListener('resize', onResize);

        animate();
      })();

      // =============================================================
      // === GAME LOGIC ==============================================
      // =============================================================
      // Finite state machine: idle → waiting → stimulus → result.
      // Early click during 'waiting' diverts to 'early' (penalty).
      // All transitions go through setPhase() — no ad-hoc state mutation.
      // Timing uses performance.now() exclusively for sub-ms accuracy.
      // =============================================================
      (() => {
        const target = document.getElementById('target');
        const panels = target.querySelectorAll('.panel');
        const resultMs = document.getElementById('result-ms');
        const resultTime = document.getElementById('result-time');
        const resultGrade = document.getElementById('result-grade');
        const headerMeta = document.getElementById('header-meta');

        const elLast = document.getElementById('stat-last');
        const elBest = document.getElementById('stat-best');
        const elAvg = document.getElementById('stat-avg');
        const elCount = document.getElementById('stat-count');

        // Session state. Lives in memory only — spec forbids persistence.
        const session = {
          times: [],
          best: null,
        };

        // Timing state for a single attempt.
        let stimulusTime = 0; // performance.now() when stimulus appeared
        let waitTimeoutId = null; // handle for the random pre-stimulus delay

        // --- helpers ---

        // Show the panel matching the current phase, hide the rest.
        // Driven by data-panel attribute so the markup is the source of truth.
        function showPanel(phase) {
          panels.forEach((p) => {
            p.classList.toggle('active', p.dataset.panel === phase);
          });
        }

        // Map raw ms to a qualitative grade. Thresholds match the spec:
        // < 250 fast (green), 250–450 average (amber), > 450 slow (red).
        function gradeFor(ms) {
          if (ms < 250) return 'fast';
          if (ms <= 450) return 'average';
          return 'slow';
        }

        function gradeLabel(g) {
          return g === 'fast'
            ? 'Excellent reflex'
            : g === 'average'
              ? 'Solid response'
              : 'Room to improve';
        }

        // Format a millisecond value for display. Mono font means we
        // don't need to pad — but we still floor for clean integers.
        const fmt = (ms) => Math.round(ms).toString();

        function updateStats() {
          if (!session.times.length) {
            elLast.textContent = '—';
            elLast.classList.add('empty');
            elBest.textContent = '—';
            elBest.classList.add('empty');
            elAvg.textContent = '—';
            elAvg.classList.add('empty');
            elCount.textContent = '0';
            return;
          }
          const last = session.times[session.times.length - 1];
          const avg =
            session.times.reduce((a, b) => a + b, 0) / session.times.length;

          elLast.innerHTML = `${fmt(last)}<span class="unit">ms</span>`;
          elLast.classList.remove('empty');

          elBest.innerHTML = `${fmt(session.best)}<span class="unit">ms</span>`;
          elBest.classList.remove('empty');

          elAvg.innerHTML = `${fmt(avg)}<span class="unit">ms</span>`;
          elAvg.classList.remove('empty');

          elCount.textContent = session.times.length.toString();
        }

        // --- the state machine ---
        // setPhase is the *only* way state changes. Each phase entry
        // handler sets up its own teardown + next-step trigger.
        function setPhase(phase, payload = {}) {
          sharedState.phase = phase;
          sharedState.grade = phase === 'result' ? payload.grade : null;
          target.dataset.state = phase;
          showPanel(phase);

          // Always clear any pending wait-timeout when transitioning.
          if (waitTimeoutId !== null) {
            clearTimeout(waitTimeoutId);
            waitTimeoutId = null;
          }

          if (phase === 'idle') {
            headerMeta.textContent = 'REACTION TEST';
          }

          if (phase === 'waiting') {
            headerMeta.textContent = 'HOLD…';
            // Random delay 1500–4000ms. Random range prevents anticipation —
            // a fixed delay would let players learn the timing.
            const delay = 1500 + Math.random() * 2500;
            waitTimeoutId = setTimeout(() => {
              // Only fire if we're still in 'waiting'. If the user clicked
              // early, the phase will already have moved to 'early'.
              if (sharedState.phase === 'waiting') {
                setPhase('stimulus');
              }
            }, delay);
          }

          if (phase === 'stimulus') {
            headerMeta.textContent = 'NOW';
            // Capture stimulus timestamp using performance.now() — gives
            // sub-millisecond precision and is monotonic, unlike Date.now().
            stimulusTime = performance.now();
            sharedState.stimulusAt = stimulusTime; // notify the 3D layer
          }

          if (phase === 'result') {
            headerMeta.textContent = `${fmt(payload.ms)}MS`;
            resultMs.textContent = fmt(payload.ms);
            resultTime.dataset.grade = payload.grade;
            resultGrade.textContent = gradeLabel(payload.grade);
          }

          if (phase === 'early') {
            headerMeta.textContent = 'TOO EARLY';
          }
        }

        // --- input handling ---
        // Single response handler — same logic whether the input came
        // from click, touch, or keyboard. Behavior depends on the phase.
        function handleResponse(e) {
          if (e) e.preventDefault();
          const now = performance.now();

          switch (sharedState.phase) {
            case 'idle':
              setPhase('waiting');
              break;

            case 'waiting': {
              // Early click — penalty branch.
              setPhase('early');
              break;
            }

            case 'stimulus': {
              // Successful reaction — measure and record.
              const ms = now - stimulusTime;
              session.times.push(ms);
              if (session.best === null || ms < session.best) session.best = ms;
              updateStats();
              setPhase('result', { ms, grade: gradeFor(ms) });
              break;
            }

            case 'result':
            case 'early':
              // Click-to-restart from any terminal state.
              setPhase('waiting');
              break;
          }
        }

        // Click + touch on the target.
        target.addEventListener('click', handleResponse);

        // Spacebar works as an alternative response — useful for
        // serious players and accessibility.
        window.addEventListener('keydown', (e) => {
          if (e.code === 'Space' || e.key === ' ') {
            handleResponse(e);
          }
        });

        // Initialize.
        setPhase('idle');
        updateStats();
      })();
    </script>
  </body>
</html>
